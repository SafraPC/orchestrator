{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orchestrator",
  "version": "1.0.7",
  "identifier": "dev.safra.orchestrator",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "capabilities": [
        "main-capabilities"
      ]
    },
    "windows": [
      {
        "label": "main",
        "title": "Orchestrator",
        "width": 1200,
        "height": 800
      }
    ]
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "publisher": "SafraPC",
    "homepage": "https://github.com/SafraPC/orchestrator",
    "license": "MIT",
    "copyright": "Copyright (c) 2026 Leandro Safra",
    "shortDescription": "Desktop app to run and manage local dev servers: Spring Boot, Laravel, Symfony, React, Next.js, NestJS, Angular, Vue, Node.js, and static HTML/PHP.",
    "longDescription": "Orchestrator is a cross-platform desktop control plane for local development. Import project folders, auto-detect Java, JavaScript, and PHP stacks, group services into containers, start and stop dev servers, follow logs, change scripts and ports, kill stuck ports, and receive auto-updates. Ideal for developers running multiple microservices, frontends, and APIs on localhost without Docker.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "resources": [
      "orchestrator-core-standalone.jar"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/share/metainfo/dev.safra.orchestrator.metainfo.xml": "linux/dev.safra.orchestrator.metainfo.xml"
        }
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "both"
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "signingIdentity": "-",
      "providerShortName": null,
      "entitlements": null,
      "dmg": {
        "background": "dmg/background.png",
        "windowSize": {
          "width": 800,
          "height": 600
        },
        "appPosition": {
          "x": 200,
          "y": 236
        },
        "applicationFolderPosition": {
          "x": 550,
          "y": 236
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI3RjgyNEMwN0Y2NUJCRTMKUldUanUyVi93Q1Q0SjQ2Q0dxUDRCY0I5N2lxRVRBV2lhZFVYMTdBbHdBTk8vRDRvZFlYWHM3dU8K",
      "endpoints": [
        "https://github.com/SafraPC/orchestrator/releases/latest/download/latest.json"
      ]
    }
  }
}
